@page "/settings/profile"
@rendermode InteractiveServer
@using NetForum.Services
@inject IForumService ForumService
@inject ICurrentUserService CurrentUserService

<PageTitle>Edit Profile — NetForum</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h2 mb-4 fw-bold text-dark"><i class="bi bi-person-gear me-2" style="color: var(--accent);"></i>Edit Profile</h1>

            @if (!CurrentUserService.IsAuthenticated)
            {
                <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center gap-2" style="border-radius: 8px;">
                    <i class="bi bi-shield-exclamation fs-5"></i>
                    <span>You must be logged in to edit your profile.</span>
                </div>
            }
            else
            {
                <div class="card p-4 shadow-sm border-0" style="border-radius: 12px; background: var(--bg-card);">
                    @if (!string.IsNullOrEmpty(_currentAvatarUrl))
                    {
                        <div class="mb-4 text-center">
                            <img src="@_currentAvatarUrl" class="rounded-circle shadow-sm" width="128" height="128"
                                 alt="Current avatar" style="object-fit: cover; border: 3px solid var(--border-color);"/>
                            <p class="text-muted small mt-2 fw-medium">Current avatar</p>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4 text-center d-flex flex-column align-items-center">
                            <div class="rounded-circle d-flex justify-content-center align-items-center shadow-sm"
                                 style="width: 128px; height: 128px; font-size: 3rem; background: var(--bg-primary); color: var(--text-secondary); border: 3px solid var(--border-color);">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <p class="text-muted small mt-2 fw-medium">No avatar set</p>
                        </div>
                    }

                    <div class="mb-4">
                        <label for="avatarInput" class="form-label fw-semibold text-secondary small">
                            <i class="bi bi-image me-1"></i>Upload New Avatar
                        </label>
                        <InputFile id="avatarInput" OnChange="HandleFileSelected" class="form-control py-2"
                                   accept="image/png, image/jpeg, image/webp" style="border-radius: 8px; box-shadow: none;"/>
                        <div class="form-text small text-muted">PNG, JPEG, or WebP. Max 5 MB.</div>
                    </div>

                    <div class="mb-4">
                        <label for="bioInput" class="form-label fw-semibold text-secondary small">
                            <i class="bi bi-card-text me-1"></i>Bio / Description
                        </label>
                        <textarea id="bioInput" @bind="_bio" @bind:event="oninput" class="form-control py-2" rows="4"
                                  maxlength="500" placeholder="Tell us about yourself..." style="border-radius: 8px; box-shadow: none;"></textarea>
                        <div class="form-text small text-muted text-end mt-1">@(_bio?.Length ?? 0) / 500 characters</div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <button class="btn text-white px-4 py-2" style="background-color: var(--accent); border-radius: 8px; font-weight: 500;" @onclick="SaveAsync" disabled="@_isLoading">
                            @if (_isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Saving Changes...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg me-1"></i>
                                <span>Save Changes</span>
                            }
                        </button>
                        <a href="/profile/@CurrentUserService.Username" class="btn btn-light px-4 py-2" style="border-radius: 8px; font-weight: 500; border: 1px solid var(--border-color);">Cancel</a>
                    </div>

                    @if (_errorMessage != null)
                    {
                        <div class="alert alert-danger mt-4 border-0 shadow-sm d-flex align-items-center gap-2" style="border-radius: 8px;">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@_errorMessage</span>
                        </div>
                    }

                    @if (_saved)
                    {
                        <div class="alert alert-success mt-4 border-0 shadow-sm d-flex align-items-center gap-2" style="border-radius: 8px; background-color: rgba(16, 185, 129, 0.1); color: var(--success);">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>Profile updated successfully.</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string? _bio;
    private string? _currentAvatarUrl;
    private IBrowserFile? _selectedFile;
    private bool _isLoading;
    private bool _saved;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUserService.IsAuthenticated)
        {
            var user = await ForumService.GetUserProfileAsync(CurrentUserService.Username);
            if (user != null)
            {
                _bio = user.Bio;
                _currentAvatarUrl = user.AvatarUrl;
            }
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _errorMessage = null;
        _saved = false;
    }

    private async Task SaveAsync()
    {
        _isLoading = true;
        _saved = false;
        _errorMessage = null;

        try
        {
            Stream? stream = null;
            string? fileName = null;
            string? contentType = null;

            if (_selectedFile != null)
            {
                stream = _selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                fileName = _selectedFile.Name;
                contentType = _selectedFile.ContentType;
            }

            await ForumService.UpdateUserProfileAsync(_bio, stream, fileName, contentType);

            _saved = true;
            _selectedFile = null;

            // Refresh avatar preview
            var updatedUser = await ForumService.GetUserProfileAsync(CurrentUserService.Username);
            _currentAvatarUrl = updatedUser?.AvatarUrl;
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (UnauthorizedAccessException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

}
