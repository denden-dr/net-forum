@page "/thread/{ThreadId:guid}"
@using NetForum.Data.Entities
@inject Services.IForumService ForumService
@inject Services.ICurrentUserService CurrentUserService

@if (_thread == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status" style="color: var(--accent) !important;"></div>
    </div>
}
else
{
    <PageTitle>NetForum - @_thread.Title</PageTitle>

    <div class="premium-card border-bottom-0 pb-4 mb-0 shadow-sm" style="border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom: 1px solid var(--border-color) !important;">
        <div class="d-flex align-items-center gap-2 mb-3">
            <span class="badge text-white px-2.5 py-1.5" style="background-color: var(--accent); border-radius: 6px; font-size: 0.75rem;">@_thread.Category?.Name</span>
            <span class="text-muted small">Started by @(_thread.Author?.Username ?? "Anonymous") • @GetTimeAgo(_thread.CreatedAt)</span>
        </div>

        <h2 class="fw-bold mb-3" style="font-size: 1.85rem; line-height: 1.3;">@_thread.Title</h2>

        <div class="fs-6 text-dark mb-4" style="line-height: 1.6; white-space: pre-wrap;">
            @_thread.Content
        </div>

        <div class="d-flex gap-4 border-top pt-3 text-muted small" style="border-top: 1px solid var(--border-color) !important; font-weight: 500;">
            <button class="upvote-btn d-flex align-items-center gap-1.5" @onclick="UpvoteMainThread">
                <i class="bi bi-caret-up-fill" style="font-size: 1.25rem;"></i>
                <span class="fw-bold text-dark">@_thread.Upvotes upvotes</span>
            </button>
            <span class="d-flex align-items-center gap-1.5 py-1">
                <i class="bi bi-eye-fill" style="color: var(--text-secondary); font-size: 1.1rem;"></i>
                <span>@_thread.Views views</span>
            </span>
        </div>
    </div>

    <div class="p-3 border border-top-0 mb-4 shadow-sm" style="background-color: #f8fafc; border-bottom-left-radius: 16px; border-bottom-right-radius: 16px; border-top: 0 !important;">
        <h5 class="fw-bold mb-3 px-2" style="font-size: 1.05rem; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 0.5px;">Replies (@(_posts?.Count ?? 0))</h5>

        @if (_posts == null)
        {
            <div class="d-flex justify-content-center my-3">
                <div class="spinner-border spinner-border-sm text-secondary" role="status" style="color: var(--accent) !important;"></div>
            </div>
        }
        else if (!_posts.Any())
        {
            <div class="text-center py-4 text-muted small" style="font-weight: 500;">
                No replies yet. Start the conversation by writing a reply below!
            </div>
        }
        else
        {
            @foreach (var post in _posts)
            {
                <div class="bg-white p-3 border rounded-3 mb-3 shadow-sm" style="border-radius: 12px !important;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold small text-dark">
                            @(post.Author?.Username ?? "Anonymous")
                            <span class="text-muted fw-normal">• @GetTimeAgo(post.CreatedAt)</span>
                        </span>
                        <div class="d-flex gap-2.5">
                            <button class="btn btn-link btn-sm text-decoration-none p-0 text-muted d-flex align-items-center gap-1 small" @onclick="() => SetReplyQuote(post)" style="box-shadow: none; font-weight: 500;">
                                <i class="bi bi-quote" style="font-size: 1rem; color: var(--accent);"></i> Reply
                            </button>
                        </div>
                    </div>

                    @if (post.ReplyToPost != null)
                    {
                        <div class="border-start border-4 bg-light p-2 mb-2 small text-secondary rounded" style="border-left-color: var(--accent) !important; border-left-width: 4px !important; background-color: #f8fafc !important;">
                            <strong>Replying to @(post.ReplyToPost.Author?.Username ?? "Anonymous"):</strong>
                            <div class="text-truncate" style="max-width: 500px;">@post.ReplyToPost.Content</div>
                        </div>
                    }

                    <div class="small text-dark mb-2.5" style="white-space: pre-wrap; line-height: 1.5;">@post.Content</div>

                    <div class="d-flex align-items-center gap-1.5 text-muted small">
                        <button class="upvote-btn btn-sm py-0 px-2" @onclick="() => UpvotePost(post.Id)">
                            <i class="bi bi-caret-up-fill"></i>
                        </button>
                        <span class="fw-semibold text-dark">@post.Upvotes votes</span>
                    </div>
                </div>
            }
        }
    </div>

    @if (CurrentUserService.IsAuthenticated && !_isEmailConfirmed)
    {
        <div class="alert alert-warning py-3 px-4 border-0 mb-4" style="border-radius: 12px; background-color: #fef3c7; color: #b45309;">
            <i class="bi bi-envelope-exclamation-fill me-2"></i>
            <strong>Verify Your Email:</strong> A confirmation link has been printed in your development terminal. Please click it to verify your account and unlock posting privileges.
        </div>
    }

    <div class="premium-card">
        <h4 class="fw-bold h5 mb-3" style="font-size: 1.15rem;">Post a Reply</h4>

        @if (_activeQuoteAuthor != null)
        {
            <div class="alert d-flex justify-content-between align-items-center py-2 px-3 mb-3 small" style="background: #e0e7ff; color: #4338ca; border: 0; border-radius: 8px; font-weight: 500;">
                <span>Replying to <strong>@@@_activeQuoteAuthor</strong></span>
                <button type="button" class="btn-close" style="font-size: 0.75rem; box-shadow: none;" @onclick="CancelQuote" disabled="@(!_isEmailConfirmed)"></button>
            </div>
        }

        <div class="mb-3">
            <label class="form-label text-secondary fw-semibold small">Message Content</label>
            <textarea class="form-control py-2" rows="4" placeholder="@(_isEmailConfirmed ? "Write your thoughts here..." : "Please verify your email address to reply to this thread.")" @bind="_replyContent" style="border-radius: 8px; box-shadow: none;" disabled="@(!_isEmailConfirmed)"></textarea>
        </div>

        <div class="text-end">
            <button class="btn text-white px-4 py-2" style="background-color: var(--accent); border-radius: 8px; font-weight: 500; opacity: @(_isEmailConfirmed ? "1" : "0.55"); cursor: @(_isEmailConfirmed ? "pointer" : "not-allowed");" @onclick="SubmitReply" disabled="@(!_isEmailConfirmed)">
                Post Reply
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ThreadId { get; set; }

    private Thread? _thread;
    private List<Post>? _posts;

    private string _replyContent = "";
    private Guid? _replyToPostId;
    private string? _activeQuoteAuthor;

    private bool _isEmailConfirmed = true;

    protected override async Task OnInitializedAsync()
    {
        _thread = await ForumService.GetThreadByIdAsync(ThreadId, incrementViewCount: true);
        if (_thread != null)
        {
            await LoadPosts();
            _isEmailConfirmed = await ForumService.IsCurrentEmailConfirmedAsync();
        }
    }

    private async Task LoadPosts()
    {
        _posts = await ForumService.GetPostsForThreadAsync(ThreadId);
    }

    private async Task UpvoteMainThread()
    {
        if (_thread == null) return;
        await ForumService.UpvoteThreadAsync(_thread.Id);
        _thread.Upvotes++;
    }

    private async Task UpvotePost(Guid postId)
    {
        await ForumService.UpvotePostAsync(postId);
        await LoadPosts();
    }

    private void SetReplyQuote(Post targetPost)
    {
        _replyToPostId = targetPost.Id;
        _activeQuoteAuthor = targetPost.Author?.Username ?? "Anonymous";

        var cleanContent = targetPost.Content.Length > 80
            ? targetPost.Content.Substring(0, 80) + "..."
            : targetPost.Content;

        // Strip previous quote blocks to avoid infinite nested quotes inside input textarea
        if (cleanContent.StartsWith(">"))
        {
            var lines = cleanContent.Split('\n');
            cleanContent = string.Join(" ", lines.Where(l => !l.StartsWith(">")).Select(l => l.Trim()));
            if (cleanContent.Length > 80)
            {
                cleanContent = cleanContent.Substring(0, 80) + "...";
            }
        }

        _replyContent = $"> @{targetPost.Author?.Username ?? "Anonymous"} said: \"{cleanContent}\"\n\n" + _replyContent;
    }

    private void CancelQuote()
    {
        _replyToPostId = null;
        _activeQuoteAuthor = null;
    }

    private async Task SubmitReply()
    {
        if (string.IsNullOrWhiteSpace(_replyContent)) return;

        await ForumService.CreatePostAsync(ThreadId, _replyContent, _replyToPostId);
        _replyContent = "";
        _replyToPostId = null;
        _activeQuoteAuthor = null;
        await LoadPosts();
    }

    private string GetTimeAgo(DateTimeOffset created)
    {
        var diff = DateTimeOffset.UtcNow - created;
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalMinutes >= 1) return $"{(int)diff.TotalMinutes}m ago";
        return "just now";
    }

}
