@inherits LayoutComponentBase
@implements IDisposable
@using NetForum.Data.Entities
@inject NavigationManager Nav
@inject Services.ICurrentUserService CurrentUserService
@inject Services.INotificationService NotificationService

<div class="nav-bar py-3 px-4 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <a href="/" class="text-decoration-none text-dark fw-bold fs-4 d-flex align-items-center">
            <i class="bi bi-code-square me-2" style="color: var(--accent);"></i>
            NetForum
        </a>
    </div>

    @if (!_isAuthPage)
    {
        <div class="d-flex align-items-center w-50">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" class="form-control border-start-0 py-2"
                       placeholder="Search discussions..."
                       style="border-radius: 0 8px 8px 0; outline: none; box-shadow: none;"
                       @bind="_searchQuery"
                       @bind:event="oninput"
                       @onkeyup="HandleSearchKeyUp"/>
            </div>
        </div>
    }

    @if (!_isAuthPage)
    {
        <div class="d-flex align-items-center gap-3">
            @if (CurrentUserService.IsAuthenticated)
            {
                <div class="position-relative me-2">
                    <button class="btn btn-link p-1 text-secondary position-relative border-0 shadow-none" style="outline: none; transition: color 0.2s;" @onclick="ToggleDropdown">
                        <i class="bi bi-bell fs-5"></i>
                        @if (_unreadCount > 0)
                        {
                            <span class="position-absolute badge rounded-pill bg-danger border border-white" style="font-size: 0.6rem; padding: 0.2em 0.4em; top: -1px; right: -1px;">@_unreadCount</span>
                        }
                    </button>

                    @if (_dropdownOpen)
                    {
                        <div class="card position-absolute shadow border" style="right: 0; top: 40px; width: 340px; z-index: 1050; border-radius: 12px; background: #ffffff; border-color: #e2e8f0;">
                            <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom py-2 px-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                                <span class="fw-bold small" style="color: var(--text-primary);">Notifications</span>
                                @if (_unreadCount > 0)
                                {
                                    <button class="btn btn-link p-0 text-decoration-none small" style="font-size: 0.75rem; color: var(--accent); font-weight: 600; box-shadow: none;" @onclick="MarkAllAsRead">
                                        Mark all as read
                                    </button>
                                }
                            </div>
                            <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                                @if (_notifications == null)
                                {
                                    <div class="p-4 text-center text-muted small">
                                        <div class="spinner-border spinner-border-sm text-secondary me-2" role="status"></div>
                                        Loading...
                                    </div>
                                }
                                else if (!_notifications.Any())
                                {
                                    <div class="p-4 text-center text-muted small">
                                        <i class="bi bi-bell-slash d-block fs-3 mb-2 text-secondary opacity-50"></i>
                                        No new notifications
                                    </div>
                                }
                                else
                                {
                                    @foreach (var notif in _notifications)
                                    {
                                        <button class="list-group-item list-group-item-action py-2 px-3 border-0 d-flex flex-column align-items-start position-relative" style="background-color: @(notif.IsRead ? "transparent" : "#f8fafc"); border-bottom: 1px solid #f1f5f9 !important; text-align: left;" @onclick="() => HandleNotificationClick(notif)">
                                            @if (!notif.IsRead)
                                            {
                                                <span class="position-absolute top-50 end-0 translate-middle-y me-3 rounded-circle" style="width: 6px; height: 6px; background-color: var(--accent);"></span>
                                            }
                                            <span class="small text-dark mb-1" style="font-weight: @(notif.IsRead ? "normal" : "600"); line-height: 1.4; padding-right: 12px;">@notif.ContentPreview</span>
                                            <span class="text-muted" style="font-size: 0.7rem;">@FormatTimeAgo(notif.CreatedAt)</span>
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (CurrentUserService.Username != Services.DevCurrentUserService.DevFallbackUsername)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="small fw-semibold text-secondary">Hi, @CurrentUserService.Username!</span>
                        <a href="/api/auth/logout" class="btn btn-link text-decoration-none text-muted p-0 small fw-medium" style="box-shadow: none;">Log Out</a>
                    </div>
                }
            }
            else
            {
                <a href="/login" class="text-decoration-none fw-semibold small px-3 py-2 text-secondary" style="border-radius: 8px; border: 1px solid var(--border-color);">Log In</a>
                <a href="/register" class="text-white text-decoration-none fw-semibold small px-3 py-2" style="background-color: var(--accent); border-radius: 8px;">Sign Up</a>
            }
            <button class="btn text-white px-4 py-2" style="background-color: var(--accent); border-radius: 8px; font-weight: 500;" @onclick="NavigateToNewThread">
                <i class="bi bi-plus-lg me-1"></i> New Thread
            </button>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center">
            <a href="/" class="text-decoration-none fw-semibold small px-3 py-2 text-secondary d-flex align-items-center gap-1" style="border-radius: 8px; border: 1px solid var(--border-color); background-color: var(--bg-card); transition: all 0.2s ease;">
                <i class="bi bi-arrow-left"></i> Back to Home
            </a>
        </div>
    }
</div>

<div class="container py-4">
    <div class="row">
        @if (!_isAuthPage)
        {
            <div class="col-lg-3 col-md-4 mb-4">
                <div class="premium-card p-3">
                    <NavMenu/>
                </div>
            </div>
            <div class="col-lg-9 col-md-8">
                @Body
            </div>
        }
        else
        {
            <div class="col-12 d-flex justify-content-center">
                <div class="w-100" style="max-width: 500px;">
                    @Body
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _searchQuery = "";
    private bool _isAuthPage;
    private List<Notification>? _notifications;
    private int _unreadCount;
    private bool _dropdownOpen;
    private Timer? _pollingTimer;

    protected override async Task OnInitializedAsync()
    {
        _isAuthPage = CheckIsAuthPage();
        Nav.LocationChanged += OnLocationChanged;

        if (CurrentUserService.IsAuthenticated && CurrentUserService.UserId.HasValue)
        {
            await LoadNotificationsAsync();

            _pollingTimer = new Timer(async void (_) =>
            {
                await InvokeAsync(async () =>
                {
                    if (CurrentUserService.IsAuthenticated && CurrentUserService.UserId.HasValue)
                    {
                        var newCount = await NotificationService.GetUnreadNotificationCountAsync(CurrentUserService.UserId.Value);
                        if (newCount != _unreadCount)
                        {
                            _unreadCount = newCount;
                            if (_dropdownOpen)
                            {
                                await LoadNotificationsAsync();
                            }

                            StateHasChanged();
                        }
                    }
                });
            }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isAuthPage = CheckIsAuthPage();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _pollingTimer?.Dispose();
    }

    private async Task LoadNotificationsAsync()
    {
        if (CurrentUserService.UserId.HasValue)
        {
            _unreadCount = await NotificationService.GetUnreadNotificationCountAsync(CurrentUserService.UserId.Value);
            _notifications = await NotificationService.GetNotificationsForUserAsync(CurrentUserService.UserId.Value);
        }
    }

    private async Task ToggleDropdown()
    {
        _dropdownOpen = !_dropdownOpen;
        if (_dropdownOpen)
        {
            await LoadNotificationsAsync();
        }
    }

    private async Task MarkAllAsRead()
    {
        if (_notifications != null && CurrentUserService.UserId.HasValue)
        {
            foreach (var notif in _notifications)
            {
                notif.IsRead = true;
            }

            _unreadCount = 0;
            StateHasChanged();

            await NotificationService.MarkAllNotificationsAsReadForUserAsync(CurrentUserService.UserId.Value);
        }
    }

    private async Task HandleNotificationClick(Notification notif)
    {
        if (!notif.IsRead)
        {
            notif.IsRead = true;
            _unreadCount = Math.Max(0, _unreadCount - 1);
            StateHasChanged();

            await NotificationService.MarkNotificationAsReadAsync(notif.Id);
        }

        _dropdownOpen = false;
        Nav.NavigateTo($"/thread/{notif.ThreadId}");
    }

    private string FormatTimeAgo(DateTimeOffset time)
    {
        var diff = DateTimeOffset.UtcNow - time;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return time.ToString("MMM dd, yyyy");
    }

    private bool CheckIsAuthPage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri).ToLowerInvariant();
        var idx = relative.IndexOf('?');
        if (idx >= 0)
        {
            relative = relative.Substring(0, idx);
        }

        return relative == "login" || relative == "register";
    }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            Nav.NavigateTo($"/?search={Uri.EscapeDataString(_searchQuery)}");
        }
    }

    private void NavigateToNewThread()
    {
        Nav.NavigateTo("/?newthread=true");
    }

}

